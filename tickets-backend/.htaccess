RewriteEngine On
RewriteBase /tickets-backend/

# Allow direct access to services.php (public endpoints)
RewriteCond %{REQUEST_URI} ^/tickets-backend/public/services\.php
RewriteRule ^.*$ - [L]

# Allow direct access to API services endpoints without going through index.php
RewriteCond %{REQUEST_URI} ^/tickets-backend/api/services
RewriteRule ^(.*)$ public/services.php [QSA,L]

# Handle API requests
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ public/index.php [QSA,L]

# Set headers for CORS
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "http://localhost:3000"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

# Handle preflight requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ - [R=200,L]
